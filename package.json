{
  "name": "neo-agent-deck",
  "version": "0.3.0",
  "description": "Turn a Stream Deck Neo into a live Claude Code, Codex, and OpenCode agent console.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Manuel Burgschachner",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-a-b-u/neo-agent-deck.git"
  },
  "bugs": {
    "url": "https://github.com/m-a-b-u/neo-agent-deck/issues"
  },
  "homepage": "https://github.com/m-a-b-u/neo-agent-deck#readme",
  "keywords": [
    "stream-deck",
    "stream-deck-neo",
    "elgato",
    "claude-code",
    "codex",
    "opencode",
    "agent",
    "hid",
    "macos",
    "windows"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json",
    "check": "npm run build && tsc -p tsconfig.test.json && npm test",
    "dev": "tsx src/index.ts",
    "doctor": "tsx scripts/doctor.ts",
    "install:mac": "bash scripts/install-macos.sh",
    "install:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-windows.ps1",
    "preview": "tsx scripts/preview.ts",
    "preview:docs": "tsx scripts/preview.ts --readme",
    "setup": "tsx scripts/setup.ts",
    "preview:live": "tsx scripts/preview.ts --live",
    "status": "tsx scripts/status.ts",
    "uninstall:mac": "bash scripts/uninstall-macos.sh",
    "uninstall:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-windows.ps1",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.6.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
